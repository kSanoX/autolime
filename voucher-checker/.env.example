# Backend API base (no trailing slash). Production: replace with prod URL.
VITE_API_URL=https://98df-46-149-89-199.ngrok-free.app/api

# Partner login: POST { login, password } → expects access_token or token in JSON
VITE_AUTH_LOGIN_PATH=/partner/login

# Free ngrok: avoids HTML warning page on fetch (set false if not using ngrok)
VITE_NGROK_SKIP_BROWSER_WARNING=true

# Voucher check: POST with Bearer. Set true only for UI dev without backend (no HTTP).
VITE_MOCK_VOUCHER_CHECK=false
VITE_VOUCHER_CHECK_PATH=/partner/voucher/check
# SMS confirm: POST { temp_code, code } — code = SMS digits from user
VITE_VOUCHER_USE_PATH=/partner/voucher/use
